{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "gbalua: Build",
      "detail": "Compile the open .lua to a .gba ROM (same name, same folder)",
      "type": "shell",
      "command": "node",
      "args": [
        "${workspaceFolder}/bin/gbalua.js",
        "build",
        "${file}",
        "-o",
        "${fileDirname}/${fileBasenameNoExtension}.gba"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    }
  ]
}
