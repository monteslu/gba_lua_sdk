{
  "name": "gbalua",
  "version": "0.4.2",
  "description": "Write Game Boy Advance games in a PICO-8-flavored Lua that compiles to native ARM.",
  "type": "module",
  "bin": {
    "gbalua": "bin/gbalua.js"
  },
  "exports": {
    ".": "./compiler/index.js",
    "./compiler/*": "./compiler/*",
    "./build": "./compiler/build-gba.mjs",
    "./bin/*": "./bin/*",
    "./gba-sdk/*": "./gba-sdk/*",
    "./package.json": "./package.json"
  },
  "engines": {
    "node": ">=24"
  },
  "dependencies": {
    "luacretro": "^0.1.0",
    "romdev-core-runner": "0.1.0",
    "romdev-maxmod": "0.1.0",
    "romdev-platform-gba": "^0.11.0"
  },
  "scripts": {
    "test": "node --test 'test/**/*.test.js'"
  },
  "keywords": [
    "lua",
    "pico-8",
    "pico8",
    "gamedev",
    "game-development",
    "retro",
    "retrogaming",
    "homebrew",
    "rom",
    "wasm",
    "webassembly",
    "ahead-of-time",
    "aot",
    "gba",
    "game-boy-advance",
    "gameboy-advance",
    "nintendo",
    "arm",
    "libtonc",
    "maxmod",
    "mgba",
    "32-bit",
    "sprites",
    "mode7"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/monteslu/gba_lua_sdk.git"
  },
  "homepage": "https://github.com/monteslu/gba_lua_sdk#readme",
  "bugs": {
    "url": "https://github.com/monteslu/gba_lua_sdk/issues"
  }
}
