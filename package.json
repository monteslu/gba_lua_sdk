{
  "name": "gbalua",
  "version": "0.4.1",
  "description": "Write Game Boy Advance games in a PICO-8-flavored Lua that compiles to native ARM.",
  "type": "module",
  "bin": {
    "gbalua": "bin/gbalua.js"
  },
  "exports": {
    "./compiler/index.js": "./compiler/index.js",
    "./compiler/peephole.js": "./compiler/peephole.js",
    "./compiler/builtins.js": "./compiler/builtins.js",
    "./compiler/build-gba.mjs": "./compiler/build-gba.mjs",
    "./compiler/png-tiles.mjs": "./compiler/png-tiles.mjs",
    "./compiler/png-encode.mjs": "./compiler/png-encode.mjs",
    "./compiler/asset-headers.mjs": "./compiler/asset-headers.mjs",
    "./compiler/soundbank.mjs": "./compiler/soundbank.mjs",
    "./compiler/ase-import.mjs": "./compiler/ase-import.mjs",
    "./compiler/tmx-import.mjs": "./compiler/tmx-import.mjs",
    "./package.json": "./package.json",
    "./compiler/xm-write.mjs": "./compiler/xm-write.mjs"
  },
  "engines": {
    "node": ">=24"
  },
  "dependencies": {
    "luacretro": "^0.1.0",
    "romdev-core-runner": "0.1.0",
    "romdev-maxmod": "0.1.0",
    "romdev-platform-gba": "^0.11.0"
  },
  "scripts": {
    "test": "node --test 'test/**/*.test.js'"
  },
  "keywords": [
    "lua",
    "pico-8",
    "pico8",
    "gamedev",
    "game-development",
    "retro",
    "retrogaming",
    "homebrew",
    "rom",
    "wasm",
    "webassembly",
    "ahead-of-time",
    "aot",
    "gba",
    "game-boy-advance",
    "gameboy-advance",
    "nintendo",
    "arm",
    "libtonc",
    "maxmod",
    "mgba",
    "32-bit",
    "sprites",
    "mode7"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/monteslu/gba_lua_sdk.git"
  },
  "homepage": "https://github.com/monteslu/gba_lua_sdk#readme",
  "bugs": {
    "url": "https://github.com/monteslu/gba_lua_sdk/issues"
  }
}
